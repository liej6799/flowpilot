+/* [op9] dump-only: vmap ANY buffer by handle, bypassing the KMD_ACCESS gate, so the
+ * BPS dump can read device-only HAL buffers (e6008e LUTs, cdm_prog table, iq). */
+int cam_mem_dbg_vmap(int32_t buf_handle, uintptr_t *vaddr_ptr, size_t *len)
+{
+	int idx, rc;
+	CAM_ERR(CAM_MEM, "[op9dbg2] ENTER hdl=%x", buf_handle);
+	if (!buf_handle || !vaddr_ptr || !len)
+		return -EINVAL;
+	idx = CAM_MEM_MGR_GET_HDL_IDX(buf_handle);
+	if (idx >= CAM_MEM_BUFQ_MAX || idx <= 0) {
+		CAM_ERR(CAM_MEM, "[op9dbg] hdl=%x bad idx=%d", buf_handle, idx);
+		return -EINVAL;
+	}
+	if (!tbl.bufq[idx].active || buf_handle != tbl.bufq[idx].buf_handle) {
+		CAM_ERR(CAM_MEM, "[op9dbg] hdl=%x idx=%d active=%d bh=%x MISMATCH",
+			buf_handle, idx, tbl.bufq[idx].active, tbl.bufq[idx].buf_handle);
+		return -EINVAL;
+	}
+	if (!tbl.bufq[idx].dma_buf) {
+		CAM_ERR(CAM_MEM, "[op9dbg] hdl=%x idx=%d NULL dma_buf flags=%x",
+			buf_handle, idx, tbl.bufq[idx].flags);
+		return -EINVAL;
+	}
+	rc = cam_mem_util_map_cpu_va(tbl.bufq[idx].dma_buf, vaddr_ptr, len);
+	if (rc)
+		CAM_ERR(CAM_MEM, "[op9dbg] hdl=%x idx=%d map_cpu_va rc=%d", buf_handle, idx, rc);
+	return rc;
+}
+EXPORT_SYMBOL(cam_mem_dbg_vmap);
+
+void cam_mem_dbg_vunmap(int32_t buf_handle, uintptr_t vaddr)
+{
+	int idx;
+	if (!buf_handle || !vaddr)
+		return;
+	idx = CAM_MEM_MGR_GET_HDL_IDX(buf_handle);
+	if (idx > 0 && idx < CAM_MEM_BUFQ_MAX && tbl.bufq[idx].dma_buf)
+		cam_mem_util_unmap_cpu_va(tbl.bufq[idx].dma_buf, vaddr);
+}
+EXPORT_SYMBOL(cam_mem_dbg_vunmap);
