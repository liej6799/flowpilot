+  mipi_data_rate = 1925500000ULL;  // [op9] 4000x3000 mode (PLL-derived)
+  mipi_settle = 2800000000ULL;     // 2.8 us (HAL CSIPHY log)
+
+  readout_time_ns = 11000000;
