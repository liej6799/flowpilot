+/* [op9] Capture the full eb0093 bps_cmd master (1.37MB) which is far too big
+ * for the kmsg ring. The kernel can't write /data files under SELinux
+ * (kernel_t denial -> EACCES), so instead we stash the buffer in vmalloc and
+ * expose it via /proc/op9_eb; the root shell does `cat /proc/op9_eb > file`
+ * with its own (allowed) write permissions.
+ * Gate: echo 2 > /sys/module/camera/parameters/op9_bps_dump (one-shot). */
+static void *op9_fdump_buf;
+static size_t op9_fdump_len;
+static int op9_eb_done;
+static struct proc_dir_entry *op9_proc_ent;
+
+static ssize_t op9_proc_read(struct file *file, char __user *ubuf,
+		size_t count, loff_t *ppos)
+{
+	size_t avail;
+
+	if (!op9_fdump_buf || *ppos >= (loff_t)op9_fdump_len)
+		return 0;
+	avail = op9_fdump_len - (size_t)*ppos;
+	if (count > avail)
+		count = avail;
+	if (copy_to_user(ubuf, (char *)op9_fdump_buf + *ppos, count))
+		return -EFAULT;
+	*ppos += count;
+	return count;
+}
+
+static const struct file_operations op9_proc_fops = {
+	.owner = THIS_MODULE,
+	.read = op9_proc_read,
+	.llseek = default_llseek,
+};
+
+/* Copy len bytes from a kernel VA into a vmalloc buffer and publish via /proc. */
+static int op9_capture_buf(const void *src, size_t len)
+{
+	op9_fdump_buf = vmalloc(len);
+	if (!op9_fdump_buf)
+		return -ENOMEM;
+	memcpy(op9_fdump_buf, src, len);
+	op9_fdump_len = len;
+	if (!op9_proc_ent)
+		op9_proc_ent = proc_create("op9_eb", 0444, NULL,
+				&op9_proc_fops);
+	return 0;
+}
